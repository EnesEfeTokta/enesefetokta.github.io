datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Statistics {
  id                String   @id @default(uuid())
  socialMetrics     Json     // nested objects
  universityMetrics Json     // nested objects
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GitHubSnapshot {
  id                String   @id @default(uuid())
  username          String
  syncedAt          DateTime @default(now())
  totalRepositories Int      @default(0)
  totalCommits      Int      @default(0)
  totalPullRequests Int      @default(0)
  languageDensity   Json?
  codeReviewsCount  Int      @default(0)
  totalStars        Int      @default(0)
  followersCount    Int      @default(0)
  openIssuesCount   Int      @default(0)
  closedIssuesCount Int      @default(0)
  rateLimit         Json?
  warnings          Json?
  createdAt         DateTime @default(now())
}